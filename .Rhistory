# packages ####
library(readr)
library(tidyverse)
# custom functions ####
pro_get <- function(df, speaker_role) {
df %>%
filter(speaker_role == {{speaker_role}}) %>% # only want one type of speaker
filter(str_detect(part_of_speech, pattern = "pro:sub|pro:obj|pro:per|pro:poss|pro:refl")) %>%  # only care about these pronouns
# even though this is tokens, it, has up to 5 different words per cell, so we have to do a complicated thing to change that.
separate(part_of_speech, sep = " ", into = c(paste("part", 1:5, sep = "")), fill = "right", remove = F) %>% #split by spaces into separate cols
separate(stem, sep = " ", into = c(paste("word", 1:5, sep = "")), fill = "right", remove = F) %>%  # same
pivot_longer(cols = word1:word5, names_to = "word_index", values_to = "word", names_prefix = "word") %>% # make this long so that we can filter out NAs
filter(!is.na(word)) %>% # filter out NAs
pivot_longer(cols = part1:part5, names_to = "pos_index", values_to = "pos", names_prefix = "part") %>% # doing the same process again for part_of_speech
filter(str_detect(pos, pattern = "pro:sub|pro:obj|pro:per|pro:poss|pro:refl"), # getting rid of everything that's not a pronoun
!is.na(pos) & # NAs
pos_index == word_index) %>% # Important! makes sure the indexes match
select(id, gloss, word, pos, speaker_id, utterance_id, corpus_id, transcript_id, speaker_role, corpus_name, everything()) %>% #re-ordering columns
filter(transcript_id %in% mot_chi_10plus$transcript_id) # getting only kids who said >10 types in transcript
}
`%nin%` = Negate(`%in%`)
age_bin <- function(df){
df %>%
mutate(child_age_bin = round(target_child_age, digits = 1)) %>%  # making .1-month age bins
filter(!is.na(target_child_name))
}
pro_count <- function(df){
df %>%  group_by(target_child_sex, collection_id, corpus_id, corpus_name, target_child_name, target_child_id, child_age_bin, word) %>%
mutate(target_child_name = as.factor(target_child_name)) %>%
summarize(pronoun_count = n()) # how many of each pronoun are said?
}
pro_type <- function(df){
df %>%
ungroup() %>%
mutate(pers_num = case_when(word %in% c("we", "us", "ours", "ourselves") ~ "first_pl",
word %in% c("I", "me", "mine", "myself") ~ "first_sg",
word %in% c("thee", "you", "you_all", "ye", "yours", "youse", "yourself","yourselves") ~ "second",
word %in% c("it", "its",
"he", "him", "his",
"she", "her", "hers",
"hisself","himself","itself", "herself") ~ "third_sg",
word %in% c("they", "them", "theirs", "themins","themselves", "each_other") ~ "third_pl",
TRUE ~ "other")) %>%  # grouping by person and number
filter(pers_num != "other")
}
pro_complete <- function(df){
df %>%
group_by(target_child_sex, collection_id, corpus_id, corpus_name, target_child_name, target_child_id, child_age_bin, pers_num) %>%
summarize(pronoun_count = sum(pronoun_count)) %>% # computing number of pronouns for each pers_num
mutate(pers_num = as.factor(pers_num)) %>% #"complete" function doesn't work on character vecs, must change to factor
complete(pers_num, fill = list(pronoun_count = 0)) # adding zeros to pers_num for children who used 0 pronouns of the corrresponding type within an age bin
}
pro_summarize <- function(df){
df %>%
ungroup() %>%
group_by(target_child_sex, collection_id, corpus_id, corpus_name, target_child_name, target_child_id, child_age_bin) %>%
mutate(total_pro_by_bin = sum(pronoun_count), # how many pronouns of each pers_num type did each kid say at each age?
prop_pers_num = pronoun_count/total_pro_by_bin)
}
pro_distinct <- function(df, pers_num){
df %>%
filter(pers_num == {{pers_num}}) %>%
distinct(utterance_id, .keep_all = TRUE) %>%  # removing duplicate utterance ids, i.e., in which pronouns were used more than once in an utterance
mutate(pers_num = {{pers_num}})
}
pro_unique <- function(df1, df2, df3, df4, df5){
rbind(df1, df2, df3, df4, df5) %>%
group_by(target_child_sex, collection_id, corpus_id, target_child_name, target_child_id, child_age_bin, pers_num) %>%
summarize(unique_pro_utts = n()) %>% # computing number of unique utterance id's for each pers_num
mutate(pers_num = as.factor(pers_num)) %>% #"complete" function doesn't work on character vecs, must change to factor
complete(pers_num, fill = list(unique_pro_utts = 0)) # adding zeros to pers_num for children who used 0 pronouns of the corresponding type within an age bin
}
totalutt <- function(df, speaker_role){
df %>%
filter(transcript_id %in% mot_chi_10plus$transcript_id, # use only transcripts in which mom +_chi used at least 10 types
speaker_role == {{speaker_role}}) %>%
mutate(child_age_bin = round(target_child_age, digits = 1)) %>%
group_by(target_child_sex, collection_id, corpus_id, target_child_name, child_age_bin) %>%
summarise(total_utt_by_bin = sum(num_utterances),
num_types_by_bin = round(mean(num_types), 1)) %>% # getting total number of utterances in each age bin
na.omit(target_child_name)
}
totalutt_summarize <- function(df1, df2){
right_join(df1, df2) %>%
ungroup() %>%
mutate(prop_pers_num = unique_pro_utts/total_utt_by_bin) %>%
relocate(pers_num, .after = child_age_bin) %>%
relocate(unique_pro_utts, .before = total_utt_by_bin)
}
data_df <- function(df, pers_num){
df %>%
filter(pers_num == {{pers_num}}) %>% # pers_num for each df
mutate(prop_pers_num_MOT_z = (prop_pers_num_MOT - mean(prop_pers_num_MOT))/(2*sd(prop_pers_num_MOT)), # standardize continuous predictor (divide by 2*SD according to Gelman, 2008)
child_age_bin_z = (child_age_bin - mean(child_age_bin))/(2*sd(child_age_bin)),
num_types_by_bin_CHI_z = (num_types_by_bin_CHI - mean(num_types_by_bin_CHI))/(2*sd(num_types_by_bin_CHI)),
num_types_by_bin_MOT_z = (num_types_by_bin_MOT - mean(num_types_by_bin_MOT))/(2*sd(num_types_by_bin_MOT))) # %>%
}
stats <- function(df, colName){ # ****************get stats func working for wider datasets
df %>%
group_by(groupminded) %>%
summarize(min_count = round(min(!! sym(colName)), 2), # analogous vars named differently in master_pro and master_utt; thus, "colName" in arguments + "!! sym(colName)" in function include var name as argument
mean_count = round(mean(!! sym(colName)), 2),
sd_count = round(sd(!! sym(colName)), 2),
median_count = round(median(!! sym(colName)), 2),
mad_count = round(mad(!! sym(colName)), 2),
max_count = round(max(!! sym(colName)), 2),
min_prop = round(min(prop_pers_num_CHI), 2), # analogous vars named identically in master_pro and master_utt
mean_prop = round(mean(prop_pers_num_CHI), 2),
median_prop = round(median(prop_pers_num_CHI), 2),
max_prop = round(max(prop_pers_num_CHI), 2),
sd_prop = round(sd(prop_pers_num_CHI), 2))
}
speaker_stats <- read_csv("data/speaker_stats.csv")
speaker_stats <- childesr::get_speaker_statistics(collection = c("Eng-NA", "Eng-UK"),
age = c(24, 72),
db_version = "2021.1")
